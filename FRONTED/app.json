{
  "expo": {
    "name": "SyncTask",
    "slug": "fronted",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/management_q13ckg.png",

    "scheme": "fronted",
    "userInterfaceStyle": "automatic",

    "ios": {
      "icon": "./assets/management_q13ckg.png",
      "bundleIdentifier": "com.anonymous.fronted"
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/management_q13ckg.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.fronted"
    },

    "web": {
      "output": "static",
      "favicon": "./assets/management_q13ckg.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/management_q13ckg.png",
          "imageWidth": 150,
          "backgroundColor": "#0B0F19",

          "android": {
            "image": "./assets/management_q13ckg.png",
            "imageWidth": 150
          },

          "ios": {
            "image": "./assets/management_q13ckg.png",
            "imageWidth": 150
          }
        }
      ],
      "expo-secure-store",
      "expo-asset"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},

      "eas": {
        "projectId": "af487fef-7ff5-4345-9629-002a4bfc3c1f"
      }
    }
  }
}